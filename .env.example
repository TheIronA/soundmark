# Copy to .env.local and fill in with your Supabase project details:
# Project Settings > API  (https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Apply the DB schema by running the SQL in supabase/migrations/ in order
# (SQL editor, or `supabase db push` if you use the Supabase CLI).
